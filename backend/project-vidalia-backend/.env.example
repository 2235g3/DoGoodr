# Environment Configuration Template
# Copy this file to .env and customize for your environment
# IMPORTANT: .env is gitignored and should never be committed

# Spring Profile: prod (requires Postgres), dev (uses H2), test (testing only)
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL Database Connection
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/vidalia_db
SPRING_DATASOURCE_USERNAME=vidalia
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_IN_PRODUCTION

# PostgreSQL Container Initialization
POSTGRES_DB=vidalia_db
POSTGRES_USER=vidalia
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# JWT Secret (REQUIRED - generate with: openssl rand -base64 32)
# NEVER use development secrets in production
APP_SECURITY_JWT_SECRET=YOUR_JWT_SECRET_HERE

# File Upload Configuration
APP_UPLOAD_ROOT_DIR=/data/uploads
APP_UPLOAD_PROFILE_PICTURES_DIR=/data/uploads/profile-pictures
APP_UPLOAD_CV_DIR=/data/uploads/cv
APP_UPLOAD_PROFILE_PICTURES_URL_PREFIX=/uploads/profile-pictures
APP_UPLOAD_CV_URL_PREFIX=/uploads/cv
APP_UPLOAD_DEFAULT_PROFILE_PICTURE_URL=/images/default-profile.png
APP_UPLOAD_MAX_FILE_SIZE=5MB
APP_UPLOAD_MAX_REQUEST_SIZE=5MB
